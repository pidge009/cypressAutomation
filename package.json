  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "delete:reports": "rm -r cypress/reports/* || true", 
    "prereport": "npm run delete:reports",
    "junit:merge": "npx junit-merge -d 'cypress/reports/junit' -o 'cypress/reports/junit/result.xml'",
    "cy-run-all":"npm run prereport && npx cypress run --browser chrome|| true && npm run junit:merge"
  },
  "devDependencies": {
    "cypress": "^15.13.1",
    "cypress-mailosaur": "^5.0.0",
    "cypress-mochawesome-reporter": "^4.0.2",
    "cypress-multi-reporters": "^2.0.5",
    "dotenv": "^17.4.1",
    "junit-merge": "^2.0.0",
    "mocha-junit-reporter": "^2.2.1"
  }
}
